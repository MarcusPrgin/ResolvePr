# ── Neon Postgres ──────────────────────────────────────────────────────────────
# From neon.tech → your project → Connection Details → Connection string
# (or auto-populated by the Vercel × Neon integration)
DATABASE_URL=

# ── Go API server ──────────────────────────────────────────────────────────────
# URL of your deployed Go backend — only needed if DATABASE_URL is not set
NEXT_PUBLIC_API_URL=

# ── GitHub OAuth App ───────────────────────────────────────────────────────────
# Create at: github.com/settings/developers → OAuth Apps → New OAuth App
# Homepage URL:      https://<your-app>.vercel.app
# Callback URL:      https://<your-app>.vercel.app/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
